// NOTE(cmat): Specify CFDR version
#version 100

// NOTE(cmat): Project title.
#project "UAP"

// NOTE(cmat): Create a colormap for the windfield.
// - We are using opacity mapping, in order to only render parts where things are interesting.
#colormap "Windfield" {
  color_0:              @hsv [ 0,   60, 100 ],
  color_1:              @hsv [ 360, 60, 100 ],
  opacity_map:          "smoothstep",
  color_map:            "hsv",
  data_map:             "custom",
  data_range:           [ 0, 5 ],
}

#colormap "Lawson" {
  color_0:              @hsv [ 0,   60, 100 ],
  color_1:              @hsv [ 360, 60, 100 ],
  opacity_map:          "smoothstep",
  color_map:            "hsv",
  data_map:             "custom",
  data_range:           [ 0, 5 ],
}

// NOTE(cmat): Setup viewport.
#viewport {
  background:       @hsv [ 255, 25, 40 ],
  orthographic:     false,
  grid_enabled:     true,
  grid_color:       @hsv [ 0, 0, 100 ],
  grid_level:       1,
  colormap:         "Windfield",
}

// NOTE(cmat): We create a basic text overlay
#overlay "Title" {
  visible:          true,
  content:          "UAP - Stockholm $/step",
  scale:            100,
  color:            @hsv [94, 16, 90],
  shadow_color:     @hsv [252, 57, 0],
  position_x:       @align "left",
  position_y:       @align "top",
  border:           [15, 5],
  background:       true,
  shadow:           true,
  shadow_offset:    1,
}

// NOTE(cmat): We can even create a watermark user the text overlay
#overlay "Watermark" {
  visible:          true,
  content:          "HiDALGO 2",
  scale:            70,
  color:            @hsv [200, 31, 22],
  opacity:          47,
  shadow_color:     @hsv [100, 20, 0],
  position_x:       @align "right",
  position_y:       @align "bottom",
  border:           [10, 0],
  background:       false,
  shadow:           false,
  shadow_offset:    1,
}

// NOTE(cmat): Terrain geometry.
#object "Terrain" {
  visible:          true,
  color:            @hsv [360, 0, 25],
  opacity:          100,
  material:         "matcap",
  surface:          "examples/uap_test/domain_surface.stl"
  scale:            [1, 1, 1]
}

// NOTE(cmat): Building geometry.
#object "Buildings" {
  visible:          true,
  color:            @hsv [200, 0, 80],
  opacity:          100,
  material:         "matcap",
  surface:          "examples/uap_test/buildings.stl",
  scale:            [1, 1, 1],
}

// NOTE(cmat): Simulation volume.
#object "Simulation" {
  visible:          true,
  volume:           [
                      [ 1,  "examples/uap_test/velocity_23.vol"  ],
                    ],
  scale:            [328, 288, 100],
}

